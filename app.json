{
  "expo": {
    "name": "RN Tredar",
    "slug": "rn-tredar",
    "owner": "r-treding-07",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "RNTredar",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trading.tredar"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.trading.tredar",
      "versionCode": 1
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Chart images scan karayla gallery access lagto.",
          "cameraPermission": false
        }
      ]
    ]
  }
}
